# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# SQLite database path (relative to prisma/)
DATABASE_URL="file:./dev.db"

# Staff portal password — change this before going live
ADMIN_PASSWORD="change-me-before-deployment"

# Full public URL of the app (used by QR code generator)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
